<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>2 John on Christian Internet Resources</title><link>https://christir.org/translations/wooden-nt/2-john/</link><description>Recent content in 2 John on Christian Internet Resources</description><generator>Hugo</generator><language>en-us</language><atom:link href="https://christir.org/translations/wooden-nt/2-john/index.xml" rel="self" type="application/rss+xml"/><item><title>2 John 1</title><link>https://christir.org/translations/wooden-nt/2-john/chapter-01/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://christir.org/translations/wooden-nt/2-john/chapter-01/</guid><description>&lt;h2 id="2-john-chapter-1">2 John Chapter 1&lt;/h2>
&lt;p class="MsoNormal" style='margin-bottom:0in;'>&lt;b>&lt;sup>&lt;span style='font-size:12.0pt;line-height:115%;font-family:"Times New Roman",serif'>                  &lt;/span>&lt;/sup>&lt;/b>&lt;span class="verse verse-v1" id="v1">&lt;sup class="verse-num">1&lt;/sup> &lt;span style='font-size:12.0pt;line-height:115%;font-family:"Times New Roman",serif'>The Elder to-the-elect lady and the children of-her, whom&lt;sup>pl&lt;/sup> I love in truth, and not only I, but all the-ones having-known the truth, &lt;/span>&lt;/span>
&lt;span class="verse verse-v2" id="v2">&lt;sup class="verse-num">2&lt;/sup> &lt;span style='font-size:12.0pt;line-height:115%;font-family:"Times New Roman",serif'>on-account-of the truth [the] residing in us and will-be with us forever&lt;sup>3&lt;/sup>.  &lt;/span>&lt;/span>
&lt;span class="verse verse-v3" id="v3">&lt;sup class="verse-num">3&lt;/sup> &lt;span style='font-size:12.0pt;line-height:115%;font-family:"Times New Roman",serif'>Grace, mercy, peace will-be with us from God (the) Father and from Jesus Christ the Son of-the Father in truth and love.&lt;/span>&lt;/span>&lt;/p></description></item></channel></rss>